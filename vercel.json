{
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap.xml"
    },
    {
      "source": "/category/:cat",
      "destination": "/category.html?cat=:cat"
    },
    {
      "source": "/:slug((?!.*\\.).*)",
      "destination": "/api/game-meta?slug=:slug"
    },
    {
      "source": "/((?!api/).*\\.(css|js|png|jpg|jpeg|svg|ico|woff|woff2))",
      "destination": "/$1.$2"
    },
    {
      "source": "/(.*)",
      "destination": "/404.html"
    }
  ]
}
