{
  "rewrites": [
    {
      "source": "/category/:cat",
      "destination": "/category.html?cat=:cat"
    },
    {
      "source": "/:slug",
      "destination": "/game.html?slug=:slug"
    },
    {
     "source": "/:path*",
      "destination": "https://vilo-ly.vercel.app/game.html"
    }
  ]
}
