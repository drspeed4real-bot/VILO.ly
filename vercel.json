{
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap.xml"
    },
    {
      "source": "/category/:cat",
      "destination": "/category.html?cat=:cat"
    },
    {
      "source": "/:slug((?!.*\\.).*)",
      "destination": "/api/game-meta?slug=:slug"
    },
      {
      "source": "/(.*)/",
      "destination": "/404.html"
    },
    {
      "source": "/(.*)",
      "destination": "/404.html"
    }
  ]
}
